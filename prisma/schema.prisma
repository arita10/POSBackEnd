// ============================================================
// POS Bakkal SaaS - Prisma Schema
// Phase 1: Core Tenancy (Shops, Users, Permissions)
// Phase 2: Stock & Inventory (ProductUnits, Products, PriceComparison)
// Phase 3: Sales & Expenses (SalesTransaction, SalesItem, ExpenseItem, Vendor)
// Phase 4: Daily Balance (DailyBalanceRecord — Devir, Fark formulas)
// Phase 5: Verisiye (VeriSiyeCustomer, VeriSiyePayment, credit sales)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SHOP - The Tenant
// ============================================================
model Shop {
  id       Int        @id @default(autoincrement())
  shopName String     @map("shop_name") @db.VarChar(100)
  status   ShopStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  productUnits        ProductUnit[]
  products            Product[]
  salesTransactions   SalesTransaction[]
  expenseItems        ExpenseItem[]
  vendors             Vendor[]
  dailyBalanceRecords DailyBalanceRecord[]
  verisiyeCustomers   VeriSiyeCustomer[]
  verisiyePayments    VeriSiyePayment[]

  @@map("shops")
}

enum ShopStatus {
  ACTIVE  @map("active")
  EXPIRED @map("expired")

  @@map("shop_status")
}

// ============================================================
// USER
// ============================================================
model User {
  id       Int      @id @default(autoincrement())
  shopId   Int      @map("shop_id")
  username String   @db.VarChar(50)
  password String   @db.VarChar(255)
  role     UserRole @default(STAFF)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  permission        Permission?
  salesTransactions SalesTransaction[]
  verisiyePayments  VeriSiyePayment[]

  @@unique([shopId, username])
  @@map("users")
}

enum UserRole {
  OWNER @map("owner")
  STAFF @map("staff")

  @@map("user_role")
}

// ============================================================
// PERMISSION
// ============================================================
model Permission {
  id             Int     @id @default(autoincrement())
  userId         Int     @unique @map("user_id")
  canManageStock Boolean @default(false) @map("can_manage_stock")
  canViewReports Boolean @default(false) @map("can_view_reports")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("permissions")
}

// ============================================================
// PRODUCT UNIT - Measurement Type (Adet / KG)
// ============================================================
model ProductUnit {
  id       Int    @id @default(autoincrement())
  shopId   Int    @map("shop_id")
  unitName String @map("unit_name") @db.VarChar(20)

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, unitName])
  @@map("product_units")
}

// ============================================================
// PRODUCT
// ============================================================
model Product {
  id            Int       @id @default(autoincrement())
  shopId        Int       @map("shop_id")
  unitId        Int       @map("unit_id")
  barcode       String?   @db.VarChar(50)
  productName   String    @map("product_name") @db.VarChar(100)
  costPrice     Decimal   @default(0) @map("cost_price") @db.Decimal(10, 2)
  salePrice     Decimal   @map("sale_price") @db.Decimal(10, 2)
  stockQuantity Decimal   @default(0) @map("stock_quantity") @db.Decimal(10, 3)
  expiryDate    DateTime? @map("expiry_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop             Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  unit             ProductUnit              @relation(fields: [unitId], references: [id])
  priceComparisons ProductPriceComparison[]
  salesItems       SalesItem[]

  @@unique([shopId, barcode])
  @@map("products")
}

// ============================================================
// PRODUCT PRICE COMPARISON
// ============================================================
model ProductPriceComparison {
  id              Int      @id @default(autoincrement())
  productId       Int      @map("product_id")
  competitorName  String   @map("competitor_name") @db.VarChar(50)
  competitorPrice Decimal  @map("competitor_price") @db.Decimal(10, 2)
  lastUpdated     DateTime @default(now()) @map("last_updated")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, competitorName])
  @@map("product_price_comparison")
}

// ============================================================
// SALES TRANSACTION - Receipt Header
//
// paymentType: "nakit" = cash, "verisiye" = credit sale
// customerId: set when paymentType = "verisiye"
// ============================================================
model SalesTransaction {
  id          Int      @id @default(autoincrement())
  shopId      Int      @map("shop_id")
  userId      Int      @map("user_id")
  totalPrice  Decimal  @map("total_price") @db.Decimal(10, 2)
  paymentType String   @default("nakit") @map("payment_type") @db.VarChar(20)
  customerId  Int?     @map("customer_id")
  createdAt   DateTime @default(now()) @map("created_at")

  shop     Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id])
  items    SalesItem[]
  customer VeriSiyeCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("sales_transactions")
}

// ============================================================
// SALES ITEM - Line Item on a Receipt
// ============================================================
model SalesItem {
  id            Int     @id @default(autoincrement())
  transactionId Int     @map("transaction_id")
  productId     Int     @map("product_id")
  quantity      Decimal @db.Decimal(10, 3)
  priceAtSale   Decimal @map("price_at_sale") @db.Decimal(10, 2)

  transaction SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id])

  @@map("sales_items")
}

// ============================================================
// VENDOR - Reusable vendor list per shop (user-managed)
// ============================================================
model Vendor {
  id         Int    @id @default(autoincrement())
  shopId     Int    @map("shop_id")
  vendorName String @map("vendor_name") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  shop     Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  expenses ExpenseItem[]

  @@unique([shopId, vendorName])
  @@map("vendors")
}

// ============================================================
// EXPENSE ITEM - Business Expenses
//
// Expense types:
//   kasa_gider  = cash expense paid from register (reduces incomeLeft)
//   devir_gider = carry-over deduction (reduces devir balance day-by-day)
//   kart_gider  = card/bank expense (reduces incomeLeft but not cash)
// ============================================================
model ExpenseItem {
  id              Int      @id @default(autoincrement())
  shopId          Int      @map("shop_id")
  vendorId        Int?     @map("vendor_id")
  vendorName      String   @map("vendor_name") @db.VarChar(100)
  itemAmount      Decimal  @map("item_amount") @db.Decimal(10, 2)
  expenseType     String   @map("expense_type") @db.VarChar(50)
  transactionDate DateTime @default(now()) @map("transaction_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@map("expense_items")
}

// ============================================================
// DAILY BALANCE RECORD - End of Day Accounting
//
// Formula 1 — Devir Kalan:
//   devirKalan = dunDevir - totalDevirGider
//
// Formula 2 — Beklenen Kasa (incomeLeft):
//   incomeLeft = totalSystemSelling - totalKasaGider - totalKartGider + devirKalan
//
// Formula 3 — Fark:
//   fark = (kasaNakit + krediler + verisiye) - incomeLeft
// ============================================================
model DailyBalanceRecord {
  id                 Int      @id @default(autoincrement())
  shopId             Int      @map("shop_id")
  recordDate         DateTime @map("record_date") @db.Date

  // Owner inputs previous day carry balance
  dunDevir           Decimal  @default(0) @map("dun_devir") @db.Decimal(10, 2)

  // System-totalled expense per type
  totalKasaGider     Decimal  @default(0) @map("total_kasa_gider") @db.Decimal(10, 2)
  totalDevirGider    Decimal  @default(0) @map("total_devir_gider") @db.Decimal(10, 2)
  totalKartGider     Decimal  @default(0) @map("total_kart_gider") @db.Decimal(10, 2)
  totalExpenseSum    Decimal  @default(0) @map("total_expense_sum") @db.Decimal(10, 2)

  totalSystemSelling Decimal  @default(0) @map("total_system_selling") @db.Decimal(10, 2)

  // Formula 1
  devirKalan         Decimal  @default(0) @map("devir_kalan") @db.Decimal(10, 2)

  // Owner manual counts
  kasaNakit          Decimal  @default(0) @map("kasa_nakit") @db.Decimal(10, 2)
  krediler           Decimal  @default(0) @map("krediler") @db.Decimal(10, 2)
  verisiye           Decimal  @default(0) @map("verisiye") @db.Decimal(10, 2)

  // Formula 2
  incomeLeft         Decimal  @default(0) @map("income_left") @db.Decimal(10, 2)

  // Formula 3
  difference         Decimal  @default(0) @map("difference") @db.Decimal(10, 2)

  createdAt          DateTime @default(now()) @map("created_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, recordDate])
  @@map("daily_balance_records")
}

// ============================================================
// VERISIYE CUSTOMER - Credit Customer per Shop
//
// homeNo: used at POS to quickly look up the customer
// telNo: unique per shop — future portal login key
// phoneHash: reserved for future customer portal authentication
// isActive: soft-delete to preserve transaction history
// @@unique([shopId, telNo]): natural login key for future portal
// ============================================================
model VeriSiyeCustomer {
  id        Int      @id @default(autoincrement())
  shopId    Int      @map("shop_id")
  name      String   @db.VarChar(100)
  homeNo    String?  @map("home_no") @db.VarChar(20)
  telNo     String   @map("tel_no") @db.VarChar(20)
  phoneHash String?  @map("phone_hash") @db.VarChar(255)
  notes     String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  salesTransactions SalesTransaction[]
  payments         VeriSiyePayment[]

  @@unique([shopId, telNo])
  @@map("verisiye_customers")
}

// ============================================================
// VERISIYE PAYMENT - Payments recorded against a credit customer
//
// Debt balance is computed dynamically:
//   balance = SUM(SalesTransaction.totalPrice WHERE customerId = x AND paymentType = 'verisiye')
//           - SUM(VeriSiyePayment.amount WHERE customerId = x)
// ============================================================
model VeriSiyePayment {
  id          Int      @id @default(autoincrement())
  shopId      Int      @map("shop_id")
  customerId  Int      @map("customer_id")
  amount      Decimal  @db.Decimal(10, 2)
  note        String?  @db.VarChar(255)
  recordedBy  Int      @map("recorded_by")
  paymentDate DateTime @default(now()) @map("payment_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer VeriSiyeCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [recordedBy], references: [id])

  @@map("verisiye_payments")
}
